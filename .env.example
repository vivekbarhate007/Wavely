# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://pulse:pulse_secret@localhost:5432/wavely
POSTGRES_USER=pulse
POSTGRES_PASSWORD=pulse_secret
POSTGRES_DB=wavely

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Reddit API (free — register at https://www.reddit.com/prefs/apps) ─────────
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=Wavely/1.0 by your_reddit_username

# ── Groq (free — https://console.groq.com) ────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
LLM_PROVIDER=groq

# ── Scraper config ─────────────────────────────────────────────────────────────
SUBREDDITS=python,MachineLearning,LocalLLaMA
SCRAPE_INTERVAL_SECONDS=300
POSTS_PER_SUBREDDIT=25

# ── App ────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
